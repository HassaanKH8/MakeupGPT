---
import "github-markdown-css/github-markdown.css";
const { frontmatter } = Astro.props;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{frontmatter?.title || "MakeupGPT Docs"}</title>

  <style>
    /* Base page */
    body {
      background-color: #0d1117; /* soft dark background */
      color: #c9d1d9; /* light gray text */
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      line-height: 1.6;
    }

    .container {
      max-width: 1000px;
      margin: auto;
      padding: 30px 20px;
    }

    /* App header */
    .app-header {
      display: flex;
      align-items: center;
      margin-bottom: 30px;
    }

    .app-header img {
      height: 50px;
      margin-right: 15px;
    }

    .app-header h1 {
      font-size: 2em;
      color: #ffffff;
      margin: 0;
    }

    /* Navbar */
    nav {
      display: flex;
      gap: 20px;
      margin-bottom: 40px;
    }

    nav a {
      color: #58a6ff;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }

    nav a:hover {
      color: #1f6feb;
    }

    /* Markdown content */
    .markdown-body {
      background: none !important;
      color: #c9d1d9 !important;
    }

    .markdown-body a {
      color: #58a6ff !important;
    }

    /* Headings */
    .markdown-body h1,
    .markdown-body h2,
    .markdown-body h3 {
      color: #ffffff !important;
    }

    /* Tables */
    .markdown-body table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
    }

    .markdown-body th,
    .markdown-body td {
      border: 1px solid #30363d !important;
      padding: 8px 12px;
      color: #c9d1d9 !important;
      background-color: #161b22 !important;
    }

    .markdown-body tbody tr:nth-child(even) td {
      background-color: #0d1117 !important;
    }

    .markdown-body tbody tr:nth-child(odd) td {
      background-color: #161b22 !important;
    }

    /* Code blocks */
    .markdown-body pre {
      background: #161b22 !important;
      color: #c9d1d9 !important;
      padding: 12px;
      border-radius: 6px;
      overflow-x: auto;
    }

    .markdown-body code {
      background: #222222 !important;
      color: #c9d1d9 !important;
      padding: 2px 6px;
      border-radius: 4px;
      font-family: 'Fira Code', monospace;
    }

    /* Blockquotes */
    .markdown-body blockquote {
      border-left: 4px solid #30363d;
      padding-left: 16px;
      color: #8b949e;
      background: #0d1117;
      border-radius: 4px;
      margin: 16px 0;
    }

    /* Lists */
    .markdown-body ul li::marker,
    .markdown-body ol li::marker {
      color: #58a6ff;
    }
  </style>
</head>

<body>
  <div class="container">
    <!-- App logo + heading -->
    <div class="app-header">
      <img src="/logo.png" alt="MakeupGPT Logo" />
      <h1>MakeupGPT</h1>
    </div>

    <!-- Modern Navbar -->
    <nav>
      <a href="/">Home</a>
      <a href="/SUPPORT">Support</a>
      <a href="/PRIVACY">Privacy</a>
      <a href="/TERMS_OF_USE">Terms</a>
    </nav>

    <!-- Markdown content -->
    <article class="markdown-body">
      <slot />
    </article>
  </div>
</body>
</html>