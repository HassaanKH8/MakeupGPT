---
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>My App</title>
  <style>
    body {
      background-color: #0d1117;
      color: #c9d1d9;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      margin: 0;
      line-height: 1.6;
    }

    .container {
      max-width: 900px;
      margin: auto;
      padding: 50px 20px;
      text-align: center;
    }

    h1 {
      font-size: 3em;
      color: #ffffff;
      margin-bottom: 0.2em;
    }

    h2 {
      font-weight: normal;
      color: #8b949e;
      margin-bottom: 1.5em;
    }

    a.button {
      display: inline-block;
      background-color: #58a6ff;
      color: #0d1117;
      padding: 12px 24px;
      border-radius: 6px;
      font-weight: 600;
      text-decoration: none;
      margin: 8px;
      transition: background 0.2s;
    }

    a.button:hover {
      background-color: #1f6feb;
    }

    nav a {
      margin: 0 12px;
      color: #58a6ff;
      text-decoration: none;
      font-weight: 500;
    }

    nav a:hover {
      text-decoration: underline;
    }
  </style>
</head>

<body>
  <div class="container">
    <!-- Logo / App Heading -->
    <img src="/logo.png" alt="MakeupGPT Logo" width="120" style="margin-bottom:20px;">
    <h1>MakeupGPT</h1>
    <h2>Your AI Makeup Artist</h2>

    <!-- Navigation buttons -->
    <div>
      <a class="button" href="/SUPPORT">Support</a>
      <a class="button" href="/PRIVACY">Privacy Policy</a>
      <a class="button" href="/TERMS_OF_USE">Terms of Use</a>
    </div>
  </div>
</body>
</html>